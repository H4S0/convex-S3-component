{
  "name": "@haso/convex-s3",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "packageManager": "pnpm@10.28.2",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/client.js",
  "types": "./dist/client.d.ts",
  "exports": {
    ".": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./convex.config": {
      "types": "./dist/convex/convex.config.d.ts",
      "default": "./dist/convex/convex.config.js"
    },
    "./convex.config.js": {
      "types": "./dist/convex/convex.config.d.ts",
      "default": "./dist/convex/convex.config.js"
    },
    "./_generated/component": {
      "types": "./dist/convex/_generated/component.d.ts",
      "default": "./dist/convex/_generated/component.js"
    },
    "./_generated/component.js": {
      "types": "./dist/convex/_generated/component.d.ts",
      "default": "./dist/convex/_generated/component.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "codegen": "convex codegen --component-dir ./convex",
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "pack:local": "pnpm run build && pnpm pack",
    "prepublishOnly": "pnpm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "convex": "^1.32.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "convex": "^1.32.0"
  }
}
